# Postgres connection string used by packages/db and apps/worker
DATABASE_URL=postgres://mcp_foundry:mcp_foundry@localhost:5432/mcp_foundry

# Anthropic API key used by packages/generator for NL -> declarative spec translation
ANTHROPIC_API_KEY=

# Secret used to sign/verify owner tokens (AuthN impl A — SignedOwnerToken, see plan §9).
# Required, >=32 characters (256-bit+) — the entire forged-token defense depends on this
# key's strength. Generate one with: openssl rand -base64 32
OWNER_TOKEN_SECRET=

# Public base URL where apps/runtime-host serves generated servers — used by
# apps/worker's Deployer to build each deployed server's public URL
# (https://{host}/s/{slug}/mcp, plan §1). Must point at RUNTIME_PORT, not
# CREATOR_PORT — apps/creator-mcp's own dashboard/status links are built from
# DASHBOARD_PUBLIC_URL / DASHBOARD_PORT instead (see apps/creator-mcp/src/index.ts).
PUBLIC_BASE_URL=http://localhost:3002

# Service ports
CREATOR_PORT=3001
RUNTIME_PORT=3002
DASHBOARD_PORT=3000

# Base URL of apps/dashboard, used by apps/creator-mcp to build dashboard/status
# links in tool responses. Optional — defaults to http://localhost:${DASHBOARD_PORT}.
DASHBOARD_PUBLIC_URL=

# Model used by packages/generator for NL -> declarative spec translation
GENERATOR_MODEL=claude-fable-5

# Comma-separated egress allowlist for the runtime-host TCB (SSRF hardening, plan §5.2)
EGRESS_ALLOWLIST=

# Directory apps/worker's Deployer writes deployed specs to, and apps/runtime-host's
# FileSpecRegistry reads them from — both processes must point at the same path.
SPEC_STORE_DIR=./data/specs

# apps/worker pipeline tuning (all optional, sensible defaults shown)
WORKER_ID=
WORKER_POLL_INTERVAL_MS=1000
WORKER_STALE_LOCK_MS=60000
WORKER_MAX_ATTEMPTS=5
