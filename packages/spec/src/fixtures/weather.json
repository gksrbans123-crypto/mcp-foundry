{
  "name": "Weather Lookup",
  "slug": "weather-lookup",
  "description": "A read-only weather lookup server generated by MCP Foundry(엠씨피 파운드리), backed by the free Open-Meteo API. Provides current conditions, a short-term forecast, and a two-location comparison.",
  "mcpVersion": "2025-06-18",
  "tools": [
    {
      "name": "get_current_weather",
      "title": "Get current weather",
      "description": "Get current weather conditions for a location via MCP Foundry(엠씨피 파운드리), backed by the free Open-Meteo API. Returns temperature, wind speed, and relative humidity as of the request time.",
      "annotations": {
        "title": "Get current weather",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "latitude": { "type": "number", "description": "Latitude in decimal degrees, e.g. 37.57 for Seoul." },
          "longitude": { "type": "number", "description": "Longitude in decimal degrees, e.g. 126.98 for Seoul." }
        },
        "required": ["latitude", "longitude"],
        "additionalProperties": false
      },
      "request": {
        "method": "GET",
        "urlTemplate": "https://api.open-meteo.com/v1/forecast",
        "headers": [{ "name": "accept", "value": "application/json" }],
        "query": [
          { "key": "latitude", "param": "latitude" },
          { "key": "longitude", "param": "longitude" },
          { "key": "current", "value": "temperature_2m,wind_speed_10m,relative_humidity_2m" },
          { "key": "timezone", "value": "auto" }
        ],
        "body": null
      },
      "response": {
        "fieldSelectors": [
          { "name": "time", "path": "current.time" },
          { "name": "temperature", "path": "current.temperature_2m" },
          { "name": "windSpeed", "path": "current.wind_speed_10m" },
          { "name": "humidity", "path": "current.relative_humidity_2m" }
        ],
        "markdownTemplate": "**Current Weather**\n\n- Time: {{time}}\n- Temperature: {{temperature}} °C\n- Wind speed: {{windSpeed}} km/h\n- Humidity: {{humidity}}%"
      },
      "cacheTtlSeconds": 300
    },
    {
      "name": "get_forecast",
      "title": "Get 3-day forecast",
      "description": "Get a 3-day temperature and precipitation forecast for a location via MCP Foundry(엠씨피 파운드리), backed by the free Open-Meteo API.",
      "annotations": {
        "title": "Get 3-day forecast",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "latitude": { "type": "number", "description": "Latitude in decimal degrees, e.g. 37.57 for Seoul." },
          "longitude": { "type": "number", "description": "Longitude in decimal degrees, e.g. 126.98 for Seoul." }
        },
        "required": ["latitude", "longitude"],
        "additionalProperties": false
      },
      "request": {
        "method": "GET",
        "urlTemplate": "https://api.open-meteo.com/v1/forecast",
        "headers": [],
        "query": [
          { "key": "latitude", "param": "latitude" },
          { "key": "longitude", "param": "longitude" },
          { "key": "daily", "value": "temperature_2m_max,temperature_2m_min,precipitation_sum" },
          { "key": "forecast_days", "value": "3" },
          { "key": "timezone", "value": "auto" }
        ],
        "body": null
      },
      "response": {
        "fieldSelectors": [
          { "name": "day1Date", "path": "daily.time[0]" },
          { "name": "day1High", "path": "daily.temperature_2m_max[0]" },
          { "name": "day1Low", "path": "daily.temperature_2m_min[0]" },
          { "name": "day1Precip", "path": "daily.precipitation_sum[0]" },
          { "name": "day2Date", "path": "daily.time[1]" },
          { "name": "day2High", "path": "daily.temperature_2m_max[1]" },
          { "name": "day2Low", "path": "daily.temperature_2m_min[1]" },
          { "name": "day2Precip", "path": "daily.precipitation_sum[1]" },
          { "name": "day3Date", "path": "daily.time[2]" },
          { "name": "day3High", "path": "daily.temperature_2m_max[2]" },
          { "name": "day3Low", "path": "daily.temperature_2m_min[2]" },
          { "name": "day3Precip", "path": "daily.precipitation_sum[2]" }
        ],
        "markdownTemplate": "**3-Day Forecast**\n\n| Date | High (°C) | Low (°C) | Precip (mm) |\n|---|---|---|---|\n| {{day1Date}} | {{day1High}} | {{day1Low}} | {{day1Precip}} |\n| {{day2Date}} | {{day2High}} | {{day2Low}} | {{day2Precip}} |\n| {{day3Date}} | {{day3High}} | {{day3Low}} | {{day3Precip}} |"
      },
      "cacheTtlSeconds": 300
    },
    {
      "name": "compare_weather",
      "title": "Compare weather between two locations",
      "description": "Compare current temperature between two locations via MCP Foundry(엠씨피 파운드리), backed by the free Open-Meteo API. Provide comma-separated coordinate pairs, e.g. latitudes=\"37.57,35.18\", longitudes=\"126.98,129.08\".",
      "annotations": {
        "title": "Compare weather between two locations",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": true
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "latitudes": { "type": "string", "description": "Comma-separated latitudes for the two locations, e.g. \"37.57,35.18\"." },
          "longitudes": { "type": "string", "description": "Comma-separated longitudes for the two locations, e.g. \"126.98,129.08\"." }
        },
        "required": ["latitudes", "longitudes"],
        "additionalProperties": false
      },
      "request": {
        "method": "GET",
        "urlTemplate": "https://api.open-meteo.com/v1/forecast",
        "headers": [],
        "query": [
          { "key": "latitude", "param": "latitudes" },
          { "key": "longitude", "param": "longitudes" },
          { "key": "current", "value": "temperature_2m" },
          { "key": "timezone", "value": "auto" }
        ],
        "body": null
      },
      "response": {
        "fieldSelectors": [
          { "name": "locationALatitude", "path": "[0].latitude" },
          { "name": "locationALongitude", "path": "[0].longitude" },
          { "name": "locationATemperature", "path": "[0].current.temperature_2m" },
          { "name": "locationBLatitude", "path": "[1].latitude" },
          { "name": "locationBLongitude", "path": "[1].longitude" },
          { "name": "locationBTemperature", "path": "[1].current.temperature_2m" }
        ],
        "markdownTemplate": "**Weather Comparison**\n\n- Location A ({{locationALatitude}}, {{locationALongitude}}): {{locationATemperature}} °C\n- Location B ({{locationBLatitude}}, {{locationBLongitude}}): {{locationBTemperature}} °C"
      },
      "cacheTtlSeconds": 300
    }
  ]
}
